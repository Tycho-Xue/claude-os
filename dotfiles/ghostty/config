#theme = light:CatppuccinLatteSubtle,dark:CitrusZest
theme = CitrusZest
font-family = JetBrains Mono
font-size = 18
font-thicken = true
window-width = 9999
window-height = 9999
window-padding-x = 16
window-padding-y = 16
window-padding-balance = true
window-padding-color = background
macos-titlebar-style = tabs
window-titlebar-background = #2d2d2d
window-titlebar-foreground = #e0e0e0
window-title-font-family = JetBrains Mono
window-save-state = always
background-opacity = 1
cursor-style = bar
cursor-style-blink = false
mouse-hide-while-typing = true
copy-on-select = clipboard
scrollback-limit = 10000000
confirm-close-surface = false
split-inherit-working-directory = true
split-divider-color = #666666
quick-terminal-position = top
quick-terminal-animation-duration = 0.2
keybind = global:ctrl+grave_accent=toggle_quick_terminal
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = ctrl+shift+left=goto_split:left
keybind = ctrl+shift+right=goto_split:right
keybind = ctrl+shift+up=goto_split:top
keybind = ctrl+shift+down=goto_split:bottom
keybind = cmd+shift+enter=toggle_split_zoom
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+left=previous_tab
keybind = cmd+right=next_tab
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+0=reset_font_size
keybind = cmd+1=text:\x01\x31
keybind = cmd+2=text:\x01\x32
keybind = cmd+3=text:\x01\x33
keybind = cmd+4=text:\x01\x34
keybind = cmd+5=text:\x01\x35
keybind = cmd+s=text:\x01\x73
keybind = cmd+z=text:\x01\x7a
keybind = cmd+alt+left=text:\x01\x70
keybind = cmd+alt+right=text:\x01\x6e
